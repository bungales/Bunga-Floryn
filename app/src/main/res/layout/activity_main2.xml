<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F0FAFA">

    <!-- Toolbar -->
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="?attr/colorPrimary"
        app:titleTextColor="@android:color/white" />

    <!-- Tombol bawah FIXED di atas scroll -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="10dp"
        android:paddingBottom="10dp"
        android:background="#F0FAFA">

        <Button
            android:id="@+id/btnKembali2"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:text="← Kembali"
            android:textSize="13sp"
            android:textStyle="bold"
            android:fontFamily="@font/inter_variablefont_opsz_wght"
            android:backgroundTint="#E3EEFF"
            android:textColor="#1565C0"
            app:cornerRadius="14dp" />

        <Button
            android:id="@+id/btnWebView2"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:text="🌐 Web Desa"
            android:textSize="13sp"
            android:textStyle="bold"
            android:fontFamily="@font/inter_variablefont_opsz_wght"
            android:backgroundTint="#1565C0"
            android:textColor="#FFFFFF"
            app:cornerRadius="14dp" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Header biru -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:background="#1565C0"
                android:paddingTop="20dp"
                android:paddingBottom="32dp">

                <androidx.cardview.widget.CardView
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    app:cardCornerRadius="32dp"
                    app:cardElevation="6dp"
                    app:cardBackgroundColor="#FFFFFF"
                    android:layout_marginBottom="10dp">
                    <ImageView
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:src="@drawable/logo"
                        android:scaleType="fitCenter"
                        android:layout_gravity="center" />
                </androidx.cardview.widget.CardView>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Kalkulator Matematika"
                    android:textSize="20sp"
                    android:textColor="#FFFFFF"
                    android:fontFamily="@font/inter_variablefont_opsz_wght"
                    android:textStyle="bold"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Hitung Luas Segitiga &amp; Volume Bola"
                    android:textSize="12sp"
                    android:textColor="#B3C6FF"
                    android:fontFamily="@font/inter_variablefont_opsz_wght" />
            </LinearLayout>

            <!-- Konten -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- Card Luas Segitiga -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="14dp"
                    android:layout_marginTop="-20dp"
                    app:cardCornerRadius="18dp"
                    app:cardElevation="8dp"
                    app:cardBackgroundColor="#FFFFFF">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="18dp">

                        <!-- Judul dengan strip biru -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="14dp">

                            <View
                                android:layout_width="4dp"
                                android:layout_height="24dp"
                                android:background="#1565C0"
                                android:layout_marginEnd="10dp" />

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="📐 Luas Segitiga"
                                android:textSize="16sp"
                                android:textStyle="bold"
                                android:textColor="#1565C0"
                                android:fontFamily="@font/inter_variablefont_opsz_wght" />

                            <com.google.android.material.card.MaterialCardView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                app:cardCornerRadius="8dp"
                                app:cardElevation="0dp"
                                app:cardBackgroundColor="#E3EEFF">
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="½ × a × t"
                                    android:textSize="11sp"
                                    android:textColor="#1565C0"
                                    android:fontFamily="@font/inter_variablefont_opsz_wght"
                                    android:textStyle="bold"
                                    android:paddingStart="8dp"
                                    android:paddingEnd="8dp"
                                    android:paddingTop="4dp"
                                    android:paddingBottom="4dp" />
                            </com.google.android.material.card.MaterialCardView>
                        </LinearLayout>

                        <!-- Input Alas -->
                        <com.google.android.material.textfield.TextInputLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="Alas (cm)"
                            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                            app:boxStrokeColor="#1565C0"
                            app:hintTextColor="#1565C0"
                            app:boxCornerRadiusTopStart="12dp"
                            app:boxCornerRadiusTopEnd="12dp"
                            app:boxCornerRadiusBottomStart="12dp"
                            app:boxCornerRadiusBottomEnd="12dp"
                            android:layout_marginBottom="10dp">
                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/et_alas_segitiga"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="numberDecimal"
                                android:fontFamily="@font/inter_variablefont_opsz_wght" />
                        </com.google.android.material.textfield.TextInputLayout>

                        <!-- Input Tinggi -->
                        <com.google.android.material.textfield.TextInputLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="Tinggi (cm)"
                            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                            app:boxStrokeColor="#1565C0"
                            app:hintTextColor="#1565C0"
                            app:boxCornerRadiusTopStart="12dp"
                            app:boxCornerRadiusTopEnd="12dp"
                            app:boxCornerRadiusBottomStart="12dp"
                            app:boxCornerRadiusBottomEnd="12dp"
                            android:layout_marginBottom="14dp">
                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/et_tinggi_segitiga"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="numberDecimal"
                                android:fontFamily="@font/inter_variablefont_opsz_wght" />
                        </com.google.android.material.textfield.TextInputLayout>

                        <Button
                            android:id="@+id/btn_hitung_segitiga"
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:text="Hitung Luas"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:fontFamily="@font/inter_variablefont_opsz_wght"
                            android:backgroundTint="#1565C0"
                            android:textColor="#FFFFFF"
                            app:cornerRadius="14dp" />

                        <!-- Hasil Segitiga -->
                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/tv_hasil_segitiga"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:visibility="gone"
                            app:cardCornerRadius="12dp"
                            app:cardElevation="0dp"
                            app:cardBackgroundColor="#E3EEFF">
                            <TextView
                                android:id="@+id/tv_hasil_segitiga_text"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Luas Segitiga: -"
                                android:textSize="15sp"
                                android:textStyle="bold"
                                android:textColor="#1565C0"
                                android:fontFamily="@font/inter_variablefont_opsz_wght"
                                android:gravity="center"
                                android:padding="14dp" />
                        </com.google.android.material.card.MaterialCardView>

                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Card Volume Bola -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="14dp"
                    app:cardCornerRadius="18dp"
                    app:cardElevation="6dp"
                    app:cardBackgroundColor="#FFFFFF">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="18dp">

                        <!-- Judul -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="14dp">

                            <View
                                android:layout_width="4dp"
                                android:layout_height="24dp"
                                android:background="#1976D2"
                                android:layout_marginEnd="10dp" />

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="⚽ Volume Bola"
                                android:textSize="16sp"
                                android:textStyle="bold"
                                android:textColor="#1565C0"
                                android:fontFamily="@font/inter_variablefont_opsz_wght" />

                            <com.google.android.material.card.MaterialCardView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                app:cardCornerRadius="8dp"
                                app:cardElevation="0dp"
                                app:cardBackgroundColor="#E3EEFF">
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="⁴⁄₃ × π × r³"
                                    android:textSize="11sp"
                                    android:textColor="#1565C0"
                                    android:fontFamily="@font/inter_variablefont_opsz_wght"
                                    android:textStyle="bold"
                                    android:paddingStart="8dp"
                                    android:paddingEnd="8dp"
                                    android:paddingTop="4dp"
                                    android:paddingBottom="4dp" />
                            </com.google.android.material.card.MaterialCardView>
                        </LinearLayout>

                        <!-- Input Jari-jari -->
                        <com.google.android.material.textfield.TextInputLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="Jari-jari (cm)"
                            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                            app:boxStrokeColor="#1565C0"
                            app:hintTextColor="#1565C0"
                            app:boxCornerRadiusTopStart="12dp"
                            app:boxCornerRadiusTopEnd="12dp"
                            app:boxCornerRadiusBottomStart="12dp"
                            app:boxCornerRadiusBottomEnd="12dp"
                            android:layout_marginBottom="14dp">
                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/et_jari_bola"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="numberDecimal"
                                android:fontFamily="@font/inter_variablefont_opsz_wght" />
                        </com.google.android.material.textfield.TextInputLayout>

                        <Button
                            android:id="@+id/btn_hitung_bola"
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:text="Hitung Volume"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:fontFamily="@font/inter_variablefont_opsz_wght"
                            android:backgroundTint="#1565C0"
                            android:textColor="#FFFFFF"
                            app:cornerRadius="14dp" />

                        <!-- Hasil Bola -->
                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/tv_hasil_bola"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:visibility="gone"
                            app:cardCornerRadius="12dp"
                            app:cardElevation="0dp"
                            app:cardBackgroundColor="#E3EEFF">
                            <TextView
                                android:id="@+id/tv_hasil_bola_text"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Volume Bola: -"
                                android:textSize="15sp"
                                android:textStyle="bold"
                                android:textColor="#1565C0"
                                android:fontFamily="@font/inter_variablefont_opsz_wght"
                                android:gravity="center"
                                android:padding="14dp" />
                        </com.google.android.material.card.MaterialCardView>

                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Info Rumus -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="14dp"
                    app:cardCornerRadius="14dp"
                    app:cardElevation="3dp"
                    app:cardBackgroundColor="#0D47A1">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="14dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="📖 Ringkasan Rumus"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:textColor="#FFFFFF"
                            android:fontFamily="@font/inter_variablefont_opsz_wght"
                            android:layout_marginBottom="8dp" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="• Luas Segitiga  =  ½ × alas × tinggi"
                            android:textSize="12sp"
                            android:textColor="#B3C6FF"
                            android:fontFamily="@font/inter_variablefont_opsz_wght"
                            android:layout_marginBottom="4dp" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="• Volume Bola  =  ⁴⁄₃ × π × r³"
                            android:textSize="12sp"
                            android:textColor="#B3C6FF"
                            android:fontFamily="@font/inter_variablefont_opsz_wght" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Tombol bawah -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="8dp">

                    <Button
                        android:id="@+id/btnKembali"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="8dp"
                        android:text="← Kembali"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:fontFamily="@font/inter_variablefont_opsz_wght"
                        android:backgroundTint="#E3EEFF"
                        android:textColor="#1565C0"
                        app:cornerRadius="14dp" />

                    <Button
                        android:id="@+id/btnWebView"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_weight="1"
                        android:text="🌐 Web Desa"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:fontFamily="@font/inter_variablefont_opsz_wght"
                        android:backgroundTint="#1565C0"
                        android:textColor="#FFFFFF"
                        app:cornerRadius="14dp" />
                </LinearLayout>

            </LinearLayout>
        </LinearLayout>
    </ScrollView>
</LinearLayout>
