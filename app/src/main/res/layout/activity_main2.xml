<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F5F5">

    <!-- Toolbar -->
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="?attr/colorPrimary"
        app:titleTextColor="@android:color/white" />

    <!-- Tombol Web Bina Desa -->
    <Button
        android:id="@+id/btnWebView"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="4dp"
        android:text="🌐  Buka Web Bina Desa"
        android:textSize="13sp"
        android:textStyle="bold"
        android:backgroundTint="#0D47A1"
        android:textColor="#FFFFFF"
        app:cornerRadius="14dp" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Tombol Kembali -->
            <Button
                android:id="@+id/btnKembali"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="←  Kembali"
                android:textSize="14sp"
                android:textStyle="bold"
                android:backgroundTint="#757575"
                android:textColor="#FFFFFF"
                android:layout_marginBottom="16dp" />

            <!-- Header -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="20dp"
                android:background="#FF6B6B"
                android:layout_marginBottom="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🌸"
                    android:textSize="40sp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Bunga-Flower"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Kalkulator Matematika"
                    android:textSize="12sp"
                    android:textColor="#FFFFFF"/>
            </LinearLayout>

            <!-- Luas Segitiga -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp"
                android:background="#FFFFFF"
                android:layout_marginBottom="16dp"
                android:elevation="4dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="📐 LUAS SEGITIGA"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#FF6B6B"
                    android:gravity="center"
                    android:layout_marginBottom="16dp"/>

                <EditText
                    android:id="@+id/et_alas_segitiga"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Alas (cm)"
                    android:inputType="numberDecimal"
                    android:padding="12dp"
                    android:background="#F5F5F5"
                    android:layout_marginBottom="12dp"/>

                <EditText
                    android:id="@+id/et_tinggi_segitiga"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Tinggi (cm)"
                    android:inputType="numberDecimal"
                    android:padding="12dp"
                    android:background="#F5F5F5"
                    android:layout_marginBottom="16dp"/>

                <Button
                    android:id="@+id/btn_hitung_segitiga"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="Hitung Luas"
                    android:backgroundTint="#FF6B6B"/>

                <TextView
                    android:id="@+id/tv_hasil_segitiga"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Hasil: -"
                    android:gravity="center"
                    android:padding="12dp"
                    android:layout_marginTop="12dp"
                    android:background="#F0F0F0"
                    android:visibility="gone"/>
            </LinearLayout>

            <!-- Volume Bola -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp"
                android:background="#FFFFFF"
                android:layout_marginBottom="16dp"
                android:elevation="4dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="⚽ VOLUME BOLA"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#4CAF50"
                    android:gravity="center"
                    android:layout_marginBottom="16dp"/>

                <EditText
                    android:id="@+id/et_jari_bola"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Jari-jari (cm)"
                    android:inputType="numberDecimal"
                    android:padding="12dp"
                    android:background="#F5F5F5"
                    android:layout_marginBottom="16dp"/>

                <Button
                    android:id="@+id/btn_hitung_bola"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="Hitung Volume"
                    android:backgroundTint="#4CAF50"/>

                <TextView
                    android:id="@+id/tv_hasil_bola"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Hasil: -"
                    android:gravity="center"
                    android:padding="12dp"
                    android:layout_marginTop="12dp"
                    android:background="#F0F0F0"
                    android:visibility="gone"/>
            </LinearLayout>

            <!-- Info Rumus -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="12dp"
                android:background="#FFF3E0"
                android:elevation="2dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="📖 INFO RUMUS\n• Luas Segitiga = ½ × alas × tinggi\n• Volume Bola = ⁴⁄₃ × π × r³"
                    android:textColor="#666666"
                    android:textSize="12sp"/>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>
</LinearLayout>
