<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1976D2">

    <ImageView
        android:id="@+id/ivOnboard2"
        android:layout_width="180dp"
        android:layout_height="180dp"
        android:src="@drawable/ic_healthtrack"
        android:scaleType="fitCenter"
        android:tint="#00BCD4"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@+id/tvTitle2"
        app:layout_constraintVertical_chainStyle="packed"
        android:layout_marginBottom="32dp" />

    <TextView
        android:id="@+id/tvTitle2"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Pantau Fasilitas Desa"
        android:textSize="26sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:fontFamily="@font/inter_variablefont_opsz_wght"
        app:layout_constraintTop_toBottomOf="@+id/ivOnboard2"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@+id/tvDesc2"
        android:layout_marginBottom="16dp" />

    <TextView
        android:id="@+id/tvDesc2"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Lihat dan pantau kondisi fasilitas desa seperti jalan, jembatan, posyandu, dan balai desa secara real-time dan transparan."
        android:textSize="15sp"
        android:textColor="#CCE3FF"
        android:fontFamily="@font/inter_variablefont_opsz_wght"
        android:textAlignment="center"
        android:lineSpacingExtra="4dp"
        android:layout_marginStart="32dp"
        android:layout_marginEnd="32dp"
        app:layout_constraintTop_toBottomOf="@+id/tvTitle2"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        android:layout_marginBottom="180dp" />

</androidx.constraintlayout.widget.ConstraintLayout>
