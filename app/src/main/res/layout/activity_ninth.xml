<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0FAFA"
    tools:context=".Home.pertemuan_9.NinthActivity">

    <!-- Toolbar -->
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="?attr/colorPrimary"
        app:titleTextColor="@android:color/white"
        app:navigationIcon="@drawable/ic_arrow_back"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Wave background header -->
    <View
        android:id="@+id/background_header"
        android:layout_width="0dp"
        android:layout_height="200dp"
        android:background="@drawable/bg_header_wave"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/toolbar" />

    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toBottomOf="@+id/toolbar"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="24dp">

            <!-- Header area di atas wave -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:paddingTop="16dp"
                android:paddingBottom="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Daftar Penduduk"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Data warga yang terdaftar di sistem desa"
                    android:textSize="12sp"
                    android:textColor="#DDEEFF"
                    android:layout_marginTop="2dp"
                    android:layout_marginBottom="12dp" />

                <!-- Stat chips row -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipTotal"
                        style="@style/Widget.MaterialComponents.Chip.Choice"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="10 Total"
                        android:textColor="#FFFFFF"
                        android:layout_marginEnd="6dp"
                        app:chipBackgroundColor="#1976D2"
                        app:chipStrokeColor="#FFFFFF"
                        app:chipStrokeWidth="1dp"
                        android:checkable="false" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipLakiStat"
                        style="@style/Widget.MaterialComponents.Chip.Choice"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="5 Laki-laki"
                        android:textColor="#FFFFFF"
                        android:layout_marginEnd="6dp"
                        app:chipBackgroundColor="#0D47A1"
                        app:chipStrokeColor="#FFFFFF"
                        app:chipStrokeWidth="1dp"
                        android:checkable="false" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipPerempuanStat"
                        style="@style/Widget.MaterialComponents.Chip.Choice"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="5 Perempuan"
                        android:textColor="#FFFFFF"
                        app:chipBackgroundColor="#0D47A1"
                        app:chipStrokeColor="#FFFFFF"
                        app:chipStrokeWidth="1dp"
                        android:checkable="false" />
                </LinearLayout>
            </LinearLayout>

            <!-- Card putih konten utama -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#F0FAFA"
                android:orientation="vertical">

                <!-- TextInputLayout Search (dengan background drawable) -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/textInputLayout"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="16dp"
                    android:layout_marginTop="16dp"
                    android:hint="Cari nama, NIK..."
                    app:errorEnabled="false"
                    app:startIconDrawable="@drawable/ic_search">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etSearch"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:imeOptions="actionSearch"
                        android:inputType="text" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- ChipGroup Filter gender -->
                <com.google.android.material.chip.ChipGroup
                    android:id="@+id/chipGroupFilter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:layout_marginTop="10dp"
                    app:singleSelection="true">

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipSemua"
                        style="@style/Widget.MaterialComponents.Chip.Filter"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:checked="true"
                        android:text="✓ Semua" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipLaki"
                        style="@style/Widget.MaterialComponents.Chip.Filter"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Laki-laki" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipPerempuan"
                        style="@style/Widget.MaterialComponents.Chip.Filter"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Perempuan" />
                </com.google.android.material.chip.ChipGroup>

                <!-- Label jumlah data -->
                <TextView
                    android:id="@+id/tvJumlahData"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:layout_marginTop="6dp"
                    android:layout_marginBottom="8dp"
                    android:text="10 data"
                    android:textColor="#757575"
                    android:textSize="12sp" />

                <!-- Section: ListView Warga -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:layout_marginTop="4dp"
                    android:layout_marginBottom="8dp"
                    android:text="Data Warga Terdaftar"
                    android:textColor="#1A1A2E"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <!-- ListView warga — non-scrollable, di dalam ScrollView -->
                <ListView
                    android:id="@+id/listViewWarga"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:divider="#E0E0E0"
                    android:dividerHeight="1dp"
                    android:nestedScrollingEnabled="false"
                    android:scrollbars="none" />

            </LinearLayout>
        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
