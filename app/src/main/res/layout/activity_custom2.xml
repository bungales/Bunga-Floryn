<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F0F4FF">

    <!-- Toolbar -->
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="#1565C0"
        app:titleTextColor="@android:color/white"
        app:subtitleTextColor="#B3C6FF" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Header -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#1565C0"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:paddingTop="8dp"
                android:paddingBottom="28dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="💪 Tips Hidup Sehat"
                    android:textSize="20sp"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold"
                    android:layout_marginBottom="4dp" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Panduan kesehatan untuk warga desa"
                    android:textSize="12sp"
                    android:textColor="#B3C6FF" />
            </LinearLayout>

            <!-- Kategori Tabs Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginTop="-20dp"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="6dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Kategori Tips"
                        android:textSize="13sp"
                        android:textColor="#1565C0"
                        android:textStyle="bold"
                        android:layout_marginBottom="12dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <!-- Makan Sehat -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="72dp"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:background="#E8F0FE"
                            android:layout_marginEnd="6dp">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="🥗" android:textSize="22sp" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Makan" android:textSize="10sp" android:textColor="#1565C0"
                                android:textStyle="bold" android:layout_marginTop="4dp" />
                        </LinearLayout>

                        <!-- Olahraga -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="72dp"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:background="#E8F5E9"
                            android:layout_marginEnd="6dp">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="🏃" android:textSize="22sp" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Olahraga" android:textSize="10sp" android:textColor="#2E7D32"
                                android:textStyle="bold" android:layout_marginTop="4dp" />
                        </LinearLayout>

                        <!-- Tidur -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="72dp"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:background="#FFF8E1"
                            android:layout_marginEnd="6dp">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="😴" android:textSize="22sp" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Istirahat" android:textSize="10sp" android:textColor="#F57F17"
                                android:textStyle="bold" android:layout_marginTop="4dp" />
                        </LinearLayout>

                        <!-- Mental -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="72dp"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:background="#FCE4EC">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="🧘" android:textSize="22sp" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Mental" android:textSize="10sp" android:textColor="#C62828"
                                android:textStyle="bold" android:layout_marginTop="4dp" />
                        </LinearLayout>

                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Tips Makan Sehat -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🥗 Pola Makan Sehat"
                android:textSize="14sp"
                android:textColor="#1565C0"
                android:textStyle="bold"
                android:layout_marginStart="16dp"
                android:layout_marginBottom="10dp" />

            <!-- Tip Card 1 -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginBottom="10dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="3dp"
                app:cardBackgroundColor="#FFFFFF">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="14dp"
                    android:gravity="center_vertical">
                    <TextView android:layout_width="40dp" android:layout_height="40dp"
                        android:text="🥦" android:textSize="22sp" android:gravity="center" />
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical" android:layout_marginStart="12dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Konsumsi Sayur &amp; Buah" android:textSize="13sp"
                            android:textColor="#212121" android:textStyle="bold" android:layout_marginBottom="3dp" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Makan minimal 5 porsi sayur dan buah setiap hari untuk kebutuhan vitamin dan serat tubuh."
                            android:textSize="11sp" android:textColor="#757575" android:lineSpacingExtra="3dp" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Tip Card 2 -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginBottom="10dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="3dp"
                app:cardBackgroundColor="#FFFFFF">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="14dp"
                    android:gravity="center_vertical">
                    <TextView android:layout_width="40dp" android:layout_height="40dp"
                        android:text="💧" android:textSize="22sp" android:gravity="center" />
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical" android:layout_marginStart="12dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Minum Air Putih Cukup" android:textSize="13sp"
                            android:textColor="#212121" android:textStyle="bold" android:layout_marginBottom="3dp" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Minum minimal 8 gelas (2 liter) air putih per hari. Hindari minuman manis berlebihan."
                            android:textSize="11sp" android:textColor="#757575" android:lineSpacingExtra="3dp" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Tip Card 3 -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="3dp"
                app:cardBackgroundColor="#FFFFFF">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="14dp"
                    android:gravity="center_vertical">
                    <TextView android:layout_width="40dp" android:layout_height="40dp"
                        android:text="🍚" android:textSize="22sp" android:gravity="center" />
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical" android:layout_marginStart="12dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Kurangi Gula &amp; Garam" android:textSize="13sp"
                            android:textColor="#212121" android:textStyle="bold" android:layout_marginBottom="3dp" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Batasi konsumsi gula harian &lt;50g dan garam &lt;5g. Gunakan rempah alami sebagai perisa."
                            android:textSize="11sp" android:textColor="#757575" android:lineSpacingExtra="3dp" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Tips Olahraga -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🏃 Aktivitas Fisik"
                android:textSize="14sp"
                android:textColor="#2E7D32"
                android:textStyle="bold"
                android:layout_marginStart="16dp"
                android:layout_marginBottom="10dp" />

            <!-- Tip Card 4 -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginBottom="10dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="3dp"
                app:cardBackgroundColor="#FFFFFF">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="14dp"
                    android:gravity="center_vertical">
                    <TextView android:layout_width="40dp" android:layout_height="40dp"
                        android:text="🚶" android:textSize="22sp" android:gravity="center" />
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical" android:layout_marginStart="12dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Jalan Kaki 30 Menit" android:textSize="13sp"
                            android:textColor="#212121" android:textStyle="bold" android:layout_marginBottom="3dp" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Jalan kaki santai 30 menit tiap hari sudah cukup menjaga kesehatan jantung dan stamina."
                            android:textSize="11sp" android:textColor="#757575" android:lineSpacingExtra="3dp" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Tip Card 5 -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="3dp"
                app:cardBackgroundColor="#FFFFFF">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="14dp"
                    android:gravity="center_vertical">
                    <TextView android:layout_width="40dp" android:layout_height="40dp"
                        android:text="🧹" android:textSize="22sp" android:gravity="center" />
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical" android:layout_marginStart="12dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Aktif di Rumah &amp; Kebun" android:textSize="13sp"
                            android:textColor="#212121" android:textStyle="bold" android:layout_marginBottom="3dp" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Kegiatan rumah tangga dan berkebun termasuk aktivitas fisik yang baik untuk tubuh."
                            android:textSize="11sp" android:textColor="#757575" android:lineSpacingExtra="3dp" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Tips Istirahat -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="😴 Istirahat &amp; Tidur"
                android:textSize="14sp"
                android:textColor="#F57F17"
                android:textStyle="bold"
                android:layout_marginStart="16dp"
                android:layout_marginBottom="10dp" />

            <!-- Tip Card 6 -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="3dp"
                app:cardBackgroundColor="#FFFFFF">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="14dp"
                    android:gravity="center_vertical">
                    <TextView android:layout_width="40dp" android:layout_height="40dp"
                        android:text="🌙" android:textSize="22sp" android:gravity="center" />
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical" android:layout_marginStart="12dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Tidur 7–8 Jam Setiap Malam" android:textSize="13sp"
                            android:textColor="#212121" android:textStyle="bold" android:layout_marginBottom="3dp" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Tidur cukup membantu memulihkan tubuh, meningkatkan daya tahan, dan menjaga kesehatan mental."
                            android:textSize="11sp" android:textColor="#757575" android:lineSpacingExtra="3dp" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Tips Kesehatan Mental -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🧘 Kesehatan Mental"
                android:textSize="14sp"
                android:textColor="#C62828"
                android:textStyle="bold"
                android:layout_marginStart="16dp"
                android:layout_marginBottom="10dp" />

            <!-- Tip Card 7 -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginBottom="10dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="3dp"
                app:cardBackgroundColor="#FFFFFF">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="14dp"
                    android:gravity="center_vertical">
                    <TextView android:layout_width="40dp" android:layout_height="40dp"
                        android:text="🤝" android:textSize="22sp" android:gravity="center" />
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical" android:layout_marginStart="12dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Jaga Silaturahmi" android:textSize="13sp"
                            android:textColor="#212121" android:textStyle="bold" android:layout_marginBottom="3dp" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Berinteraksi sosial dan menjaga hubungan baik dengan tetangga dapat menurunkan stress."
                            android:textSize="11sp" android:textColor="#757575" android:lineSpacingExtra="3dp" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Tip Card 8 -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginBottom="24dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="3dp"
                app:cardBackgroundColor="#FFFFFF">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="14dp"
                    android:gravity="center_vertical">
                    <TextView android:layout_width="40dp" android:layout_height="40dp"
                        android:text="🏥" android:textSize="22sp" android:gravity="center" />
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical" android:layout_marginStart="12dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Rutin Periksa ke Puskesmas" android:textSize="13sp"
                            android:textColor="#212121" android:textStyle="bold" android:layout_marginBottom="3dp" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Lakukan pemeriksaan kesehatan rutin minimal 6 bulan sekali meski tidak ada keluhan."
                            android:textSize="11sp" android:textColor="#757575" android:lineSpacingExtra="3dp" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </ScrollView>

</LinearLayout>
