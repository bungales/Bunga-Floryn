<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:orientation="vertical"
    android:padding="12dp">

    <!-- CARD -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1.2"
        app:cardCornerRadius="20dp"
        app:cardElevation="6dp"
        android:layout_marginBottom="12dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:padding="16dp"
            android:gravity="center">

            <androidx.cardview.widget.CardView
                android:layout_width="60dp"
                android:layout_height="60dp"
                app:cardCornerRadius="30dp"
                app:cardElevation="6dp"
                android:layout_marginBottom="8dp">

                <ImageView
                    android:id="@+id/ivLogo"
                    android:layout_width="45dp"
                    android:layout_height="45dp"
                    android:src="@drawable/ic_healthtrack"
                    android:layout_gravity="center" />
            </androidx.cardview.widget.CardView>

            <TextView
                android:id="@+id/tvAppTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="HealthTrack"
                android:textSize="22sp"
                android:textColor="@color/primary_dark"
                android:fontFamily="@font/inter_variablefont_opsz_wght"
                android:textStyle="bold"
                android:layout_marginBottom="4dp" />

            <TextView
                android:id="@+id/tvWelcomeMessage"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Selamat Datang,"
                android:textSize="13sp"
                android:textColor="@color/text_light"
                android:fontFamily="@font/inter_variablefont_opsz_wght"
                android:layout_marginBottom="2dp" />

            <TextView
                android:id="@+id/tvUsername"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="User"
                android:textSize="20sp"
                android:textColor="@color/primary_blue"
                android:fontFamily="@font/inter_variablefont_opsz_wght"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <View
                android:layout_width="35dp"
                android:layout_height="2dp"
                android:background="@color/primary_blue"
                android:layout_marginBottom="10dp" />

            <TextView
                android:id="@+id/tvDescription"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Sakit itu penting, tapi tak ada yang suka sakit. Kita mungkin merasakannya, namun semua akan berlalu."
                android:textSize="11sp"
                android:textColor="@color/text_light"
                android:fontFamily="@font/inter_variablefont_opsz_wght"
                android:textAlignment="center"
                android:lineSpacingExtra="2dp" />

        </LinearLayout>

    </androidx.cardview.widget.CardView>

    <!-- TOMBOL 1 -->
    <Button
        android:id="@+id/btnRumusBangunRuang"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:text="📐 Rumus Bangun Ruang"
        android:textSize="13sp"
        android:textStyle="bold"
        android:backgroundTint="@color/primary_blue"
        android:textColor="@color/white"
        app:cornerRadius="10dp"
        android:layout_marginBottom="8dp" />

    <!-- TOMBOL 2 -->
    <Button
        android:id="@+id/btnCustom1"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:text="🎨 Custom Screen 1"
        android:textSize="13sp"
        android:textStyle="bold"
        android:backgroundTint="@color/purple_primary"
        android:textColor="@color/white"
        app:cornerRadius="10dp"
        android:layout_marginBottom="8dp" />

    <!-- TOMBOL 3 -->
    <Button
        android:id="@+id/btnCustom2"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:text="🎯 Custom Screen 2"
        android:textSize="13sp"
        android:textStyle="bold"
        android:backgroundTint="@color/orange_accent"
        android:textColor="@color/white"
        app:cornerRadius="10dp"
        android:layout_marginBottom="8dp" />

    <!-- TOMBOL 4 LOGOUT -->
    <Button
        android:id="@+id/btnLogout"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:text="🚪 Logout"
        android:textSize="13sp"
        android:textStyle="bold"
        android:backgroundTint="@color/red_error"
        android:textColor="@color/white"
        app:cornerRadius="10dp"
        android:layout_marginTop="4dp"
        android:layout_marginBottom="0dp" />

</LinearLayout>