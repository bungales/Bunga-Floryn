<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0FAFA"
    android:orientation="vertical">

    <!-- Header teal -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="200dp"
        android:orientation="vertical"
        android:gravity="center"
        android:background="#00BCD4"
        android:paddingBottom="28dp">

        <androidx.cardview.widget.CardView
            android:layout_width="72dp"
            android:layout_height="72dp"
            app:cardCornerRadius="36dp"
            app:cardElevation="6dp"
            app:cardBackgroundColor="#FFFFFF"
            android:layout_marginBottom="10dp">

            <ImageView
                android:id="@+id/ivLogo"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:src="@drawable/ic_healthtrack"
                android:tint="#00BCD4"
                android:layout_gravity="center" />
        </androidx.cardview.widget.CardView>

        <TextView
            android:id="@+id/tvAppTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="HealthTrack"
            android:textSize="24sp"
            android:textColor="#FFFFFF"
            android:fontFamily="@font/inter_variablefont_opsz_wght"
            android:textStyle="bold"
            android:layout_marginBottom="4dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Pantau kesehatan Anda, hidup lebih baik"
            android:textSize="12sp"
            android:textColor="#E0F7FA"
            android:fontFamily="@font/inter_variablefont_opsz_wght" />
    </LinearLayout>

    <!-- Card melayang -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        android:layout_marginTop="-24dp"
        android:layout_marginBottom="16dp"
        app:cardCornerRadius="20dp"
        app:cardElevation="8dp"
        app:cardBackgroundColor="#FFFFFF">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp"
            android:gravity="center">

            <TextView
                android:id="@+id/tvWelcomeMessage"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Selamat Datang,"
                android:textSize="13sp"
                android:textColor="#90A4AE"
                android:fontFamily="@font/inter_variablefont_opsz_wght"
                android:layout_marginBottom="2dp" />

            <TextView
                android:id="@+id/tvUsername"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="User"
                android:textSize="22sp"
                android:textColor="#00BCD4"
                android:fontFamily="@font/inter_variablefont_opsz_wght"
                android:textStyle="bold"
                android:layout_marginBottom="10dp" />

            <View
                android:layout_width="40dp"
                android:layout_height="2dp"
                android:background="#00BCD4"
                android:layout_marginBottom="10dp" />

            <TextView
                android:id="@+id/tvDescription"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Pilih menu di bawah untuk mulai memantau kesehatanmu hari ini."
                android:textSize="12sp"
                android:textColor="#90A4AE"
                android:fontFamily="@font/inter_variablefont_opsz_wght"
                android:textAlignment="center"
                android:lineSpacingExtra="3dp" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Buttons area -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp">

        <Button
            android:id="@+id/btnRumusBangunRuang"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:text="📐  Rumus Bangun Ruang"
            android:textSize="13sp"
            android:textStyle="bold"
            android:backgroundTint="#00BCD4"
            android:textColor="#FFFFFF"
            app:cornerRadius="14dp"
            android:layout_marginBottom="10dp" />

        <Button
            android:id="@+id/btnCustom1"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:text="🏥  Specialties"
            android:textSize="13sp"
            android:textStyle="bold"
            android:backgroundTint="#00ACC1"
            android:textColor="#FFFFFF"
            app:cornerRadius="14dp"
            android:layout_marginBottom="10dp" />

        <Button
            android:id="@+id/btnCustom2"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:text="🏠  Home Dashboard"
            android:textSize="13sp"
            android:textStyle="bold"
            android:backgroundTint="#0097A7"
            android:textColor="#FFFFFF"
            app:cornerRadius="14dp"
            android:layout_marginBottom="10dp" />

        <Button
            android:id="@+id/btnLogout"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:text="🚪  Logout"
            android:textSize="13sp"
            android:textStyle="bold"
            android:backgroundTint="#E0F7FA"
            android:textColor="#00838F"
            app:cornerRadius="14dp" />

    </LinearLayout>

</LinearLayout>
