<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- CARD YANG SUDAH ADA -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="24dp"
            app:cardElevation="8dp"
            android:layout_marginBottom="24dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="30dp"
                android:gravity="center">

                <androidx.cardview.widget.CardView
                    android:layout_width="90dp"
                    android:layout_height="90dp"
                    app:cardCornerRadius="45dp"
                    app:cardElevation="8dp"
                    android:layout_marginBottom="16dp">

                    <ImageView
                        android:id="@+id/ivLogo"
                        android:layout_width="60dp"
                        android:layout_height="60dp"
                        android:src="@drawable/ic_healthtrack"
                        android:layout_gravity="center" />
                </androidx.cardview.widget.CardView>

                <TextView
                    android:id="@+id/tvAppTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="HealthTrack"
                    android:textSize="28sp"
                    android:textColor="@color/primary_dark"
                    android:fontFamily="@font/inter_variablefont_opsz_wght"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:id="@+id/tvWelcomeMessage"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Selamat Datang,"
                    android:textSize="16sp"
                    android:textColor="@color/text_light"
                    android:fontFamily="@font/inter_variablefont_opsz_wght"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:id="@+id/tvUsername"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="User"
                    android:textSize="24sp"
                    android:textColor="@color/primary_blue"
                    android:fontFamily="@font/inter_variablefont_opsz_wght"
                    android:textStyle="bold"
                    android:layout_marginBottom="16dp" />

                <View
                    android:layout_width="50dp"
                    android:layout_height="2dp"
                    android:background="@color/primary_blue"
                    android:layout_marginBottom="16dp" />

                <TextView
                    android:id="@+id/tvDescription"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Sesungguhnya, sakit itu sendiri penting, akan tetapi sebagian dari kita mungkin mengabaikannya. Tidak ada yang suka pada kesakitan, tidak juga mencarinya, namun karena itu semua terjadi secara alami. Kita mungkin pernah merasakan sakit yang luar biasa, dan itu semua akan berlalu."
                    android:textSize="13sp"
                    android:textColor="@color/text_light"
                    android:fontFamily="@font/inter_variablefont_opsz_wght"
                    android:textAlignment="center"
                    android:lineSpacingExtra="4dp" />

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- TOMBOL 1 -->
        <Button
            android:id="@+id/btnRumusBangunRuang"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:text="📐  Rumus Bangun Ruang"
            android:textSize="15sp"
            android:textStyle="bold"
            android:backgroundTint="@color/primary_blue"
            android:textColor="@color/white"
            app:cornerRadius="12dp"
            android:layout_marginBottom="12dp" />

        <!-- TOMBOL 2 -->
        <Button
            android:id="@+id/btnCustom1"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:text="🎨  Custom Screen 1"
            android:textSize="15sp"
            android:textStyle="bold"
            android:backgroundTint="@color/purple_primary"
            android:textColor="@color/white"
            app:cornerRadius="12dp"
            android:layout_marginBottom="12dp" />

        <!-- TOMBOL 3 -->
        <Button
            android:id="@+id/btnCustom2"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:text="🎯  Custom Screen 2"
            android:textSize="15sp"
            android:textStyle="bold"
            android:backgroundTint="@color/orange_accent"
            android:textColor="@color/white"
            app:cornerRadius="12dp"
            android:layout_marginBottom="12dp" />

        <!-- TOMBOL 4 LOGOUT -->
        <Button
            android:id="@+id/btnLogout"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:text="🚪  Logout"
            android:textSize="15sp"
            android:textStyle="bold"
            android:backgroundTint="@color/red_error"
            android:textColor="@color/white"
            app:cornerRadius="12dp"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="20dp" />

    </LinearLayout>

</ScrollView>