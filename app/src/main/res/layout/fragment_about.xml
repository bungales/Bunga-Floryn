<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0FAFA"
    tools:context=".About.AboutFragment">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="?attr/colorPrimary"
        app:titleTextColor="@android:color/white"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Header Card -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardHeader"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="14dp"
        android:layout_marginEnd="14dp"
        android:layout_marginTop="10dp"
        app:cardCornerRadius="16dp"
        app:cardElevation="6dp"
        app:cardBackgroundColor="#1565C0"
        app:layout_constraintTop_toBottomOf="@+id/toolbar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="14dp"
            android:gravity="center_vertical">

            <ImageView
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@drawable/logo"
                android:scaleType="fitCenter"
                android:layout_marginEnd="12dp" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Sistem Pengelolaan Fasilitas Desa"
                    android:textSize="14sp"
                    android:textColor="#FFFFFF"
                    android:fontFamily="@font/inter_variablefont_opsz_wght"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Bina Desa — RuangKu  •  v1.0.0"
                    android:textSize="11sp"
                    android:textColor="#B3C6FF"
                    android:fontFamily="@font/inter_variablefont_opsz_wght"
                    android:layout_marginTop="2dp" />
            </LinearLayout>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Deskripsi -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardDesc"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="14dp"
        android:layout_marginEnd="14dp"
        android:layout_marginTop="8dp"
        app:cardCornerRadius="14dp"
        app:cardElevation="3dp"
        app:cardBackgroundColor="#FFFFFF"
        app:layout_constraintTop_toBottomOf="@+id/cardHeader"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📋 Tentang Aplikasi"
                android:textSize="12sp"
                android:textColor="#1565C0"
                android:fontFamily="@font/inter_variablefont_opsz_wght"
                android:textStyle="bold"
                android:layout_marginBottom="5dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Kelola peminjaman balai, lapangan, dan fasilitas desa lainnya dengan mudah melalui dashboard admin. Pantau jadwal, persetujuan, dan data peminjaman secara real-time."
                android:textSize="11sp"
                android:textColor="#424242"
                android:fontFamily="@font/inter_variablefont_opsz_wght"
                android:lineSpacingExtra="2dp" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Fitur Utama — GridLayout -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardFiturUtama"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="14dp"
        android:layout_marginEnd="14dp"
        android:layout_marginTop="8dp"
        app:cardCornerRadius="14dp"
        app:cardElevation="3dp"
        app:cardBackgroundColor="#FFFFFF"
        app:layout_constraintTop_toBottomOf="@+id/cardDesc"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⚡ Fitur Utama"
                android:textSize="13sp"
                android:textColor="#1565C0"
                android:fontFamily="@font/inter_variablefont_opsz_wght"
                android:textStyle="bold"
                android:layout_marginBottom="10dp" />

            <androidx.gridlayout.widget.GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:columnCount="2"
                app:useDefaultMargins="true">

                <!-- Fasilitas Umum -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardFasilitasUmum"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="10dp"
                    app:cardElevation="2dp"
                    app:cardBackgroundColor="#EEF2FF"
                    app:layout_columnWeight="1"
                    app:layout_gravity="fill_horizontal">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="72dp"
                        android:orientation="vertical" android:gravity="center" android:padding="8dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="🏛️" android:textSize="22sp" android:gravity="center" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Fasilitas Umum" android:textSize="11sp" android:textColor="#1565C0"
                            android:textStyle="bold" android:gravity="center" android:layout_marginTop="4dp"
                            android:fontFamily="@font/inter_variablefont_opsz_wght" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Peminjaman Fasilitas -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardPeminjaman"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="10dp"
                    app:cardElevation="2dp"
                    app:cardBackgroundColor="#EEF2FF"
                    app:layout_columnWeight="1"
                    app:layout_gravity="fill_horizontal">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="72dp"
                        android:orientation="vertical" android:gravity="center" android:padding="8dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="🤝" android:textSize="22sp" android:gravity="center" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Peminjaman" android:textSize="11sp" android:textColor="#1565C0"
                            android:textStyle="bold" android:gravity="center" android:layout_marginTop="4dp"
                            android:fontFamily="@font/inter_variablefont_opsz_wght" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Pembayaran Fasilitas -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardPembayaran"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="10dp"
                    app:cardElevation="2dp"
                    app:cardBackgroundColor="#EEF2FF"
                    app:layout_columnWeight="1"
                    app:layout_gravity="fill_horizontal">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="72dp"
                        android:orientation="vertical" android:gravity="center" android:padding="8dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="💳" android:textSize="22sp" android:gravity="center" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Pembayaran" android:textSize="11sp" android:textColor="#1565C0"
                            android:textStyle="bold" android:gravity="center" android:layout_marginTop="4dp"
                            android:fontFamily="@font/inter_variablefont_opsz_wght" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Syarat Fasilitas -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardSyarat"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="10dp"
                    app:cardElevation="2dp"
                    app:cardBackgroundColor="#EEF2FF"
                    app:layout_columnWeight="1"
                    app:layout_gravity="fill_horizontal">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="72dp"
                        android:orientation="vertical" android:gravity="center" android:padding="8dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="📋" android:textSize="22sp" android:gravity="center" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Syarat Fasilitas" android:textSize="11sp" android:textColor="#1565C0"
                            android:textStyle="bold" android:gravity="center" android:layout_marginTop="4dp"
                            android:fontFamily="@font/inter_variablefont_opsz_wght" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Petugas Fasilitas -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardPetugas"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="10dp"
                    app:cardElevation="2dp"
                    app:cardBackgroundColor="#EEF2FF"
                    app:layout_columnWeight="1"
                    app:layout_gravity="fill_horizontal">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="72dp"
                        android:orientation="vertical" android:gravity="center" android:padding="8dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="👮" android:textSize="22sp" android:gravity="center" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Petugas Fasilitas" android:textSize="11sp" android:textColor="#1565C0"
                            android:textStyle="bold" android:gravity="center" android:layout_marginTop="4dp"
                            android:fontFamily="@font/inter_variablefont_opsz_wght" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Data Warga -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardDataWarga"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="10dp"
                    app:cardElevation="2dp"
                    app:cardBackgroundColor="#EEF2FF"
                    app:layout_columnWeight="1"
                    app:layout_gravity="fill_horizontal">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="72dp"
                        android:orientation="vertical" android:gravity="center" android:padding="8dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="👥" android:textSize="22sp" android:gravity="center" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Data Warga" android:textSize="11sp" android:textColor="#1565C0"
                            android:textStyle="bold" android:gravity="center" android:layout_marginTop="4dp"
                            android:fontFamily="@font/inter_variablefont_opsz_wght" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

            </androidx.gridlayout.widget.GridLayout>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Master Data & User -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="14dp"
        android:layout_marginEnd="14dp"
        android:layout_marginTop="8dp"
        app:cardCornerRadius="14dp"
        app:cardElevation="3dp"
        app:cardBackgroundColor="#3949AB"
        app:layout_constraintTop_toBottomOf="@+id/cardFiturUtama"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="12dp"
            android:gravity="center_vertical">

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="👤 " android:textSize="16sp" />

            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="User Management"
                    android:textSize="12sp" android:textColor="#FFFFFF"
                    android:fontFamily="@font/inter_variablefont_opsz_wght" android:textStyle="bold" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="• Lihat Data   • Tambah Data"
                    android:textSize="11sp" android:textColor="#C5CAE9"
                    android:fontFamily="@font/inter_variablefont_opsz_wght"
                    android:layout_marginTop="2dp" />
            </LinearLayout>

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="🔐" android:textSize="16sp" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>
