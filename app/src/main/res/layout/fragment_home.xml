<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0FAFA"
    tools:context=".Home.HomeFragment">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="?attr/colorPrimary"
        app:titleTextColor="@android:color/white"
        app:subtitleTextColor="@android:color/white"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <!-- Tombol logout di kanan toolbar -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="end"
            android:layout_marginEnd="8dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <Button
                android:id="@+id/btnLogout"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="Logout"
                android:textSize="12sp"
                android:textStyle="bold"
                android:backgroundTint="#FFFFFF"
                android:textColor="#1565C0"
                app:cornerRadius="18dp"
                android:paddingStart="14dp"
                android:paddingEnd="14dp" />
        </LinearLayout>

    </androidx.appcompat.widget.Toolbar>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@+id/toolbar"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Header -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="160dp"
                android:orientation="vertical"
                android:gravity="center"
                android:background="#1565C0"
                android:paddingBottom="28dp">

                <androidx.cardview.widget.CardView
                    android:layout_width="72dp"
                    android:layout_height="72dp"
                    app:cardCornerRadius="36dp"
                    app:cardElevation="6dp"
                    app:cardBackgroundColor="#FFFFFF"
                    android:layout_marginBottom="10dp">

                    <ImageView
                        android:id="@+id/ivLogo"
                        android:layout_width="52dp"
                        android:layout_height="52dp"
                        android:src="@drawable/logo"
                        android:scaleType="fitCenter"
                        android:layout_gravity="center" />
                </androidx.cardview.widget.CardView>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Sistem Pengelolaan Fasilitas Desa"
                    android:textSize="14sp"
                    android:textColor="#FFFFFF"
                    android:fontFamily="@font/inter_variablefont_opsz_wght"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Card Welcome -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:layout_marginEnd="20dp"
                android:layout_marginTop="-24dp"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="8dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp"
                    android:gravity="center">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Selamat Datang,"
                        android:textSize="13sp"
                        android:textColor="#90A4AE"
                        android:fontFamily="@font/inter_variablefont_opsz_wght"
                        android:layout_marginBottom="2dp" />

                    <TextView
                        android:id="@+id/tvUsername"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="User"
                        android:textSize="22sp"
                        android:textColor="#1565C0"
                        android:fontFamily="@font/inter_variablefont_opsz_wght"
                        android:textStyle="bold"
                        android:layout_marginBottom="10dp" />

                    <View
                        android:layout_width="40dp"
                        android:layout_height="2dp"
                        android:background="#1565C0"
                        android:layout_marginBottom="10dp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Silahkan pilih menu di bawah ini"
                        android:textSize="12sp"
                        android:textColor="#757575"
                        android:fontFamily="@font/inter_variablefont_opsz_wght"
                        android:textAlignment="center" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Buttons -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="20dp"
                android:paddingEnd="20dp">

                <Button
                    android:id="@+id/btnRumusBangunRuang"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:text="📐  Rumus Bangun Ruang"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:backgroundTint="#1565C0"
                    android:textColor="#FFFFFF"
                    app:cornerRadius="14dp"
                    android:layout_marginBottom="10dp" />

                <Button
                    android:id="@+id/btnCustom1"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:text="🏥  Cek Kesehatan"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:backgroundTint="#1976D2"
                    android:textColor="#FFFFFF"
                    app:cornerRadius="14dp"
                    android:layout_marginBottom="10dp" />

                <Button
                    android:id="@+id/btnCustom2"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:text="📅  Jadwal &amp; Tips Sehat"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:backgroundTint="#0D47A1"
                    android:textColor="#FFFFFF"
                    app:cornerRadius="14dp"
                    android:layout_marginBottom="10dp" />

                <Button
                    android:id="@+id/btnPertemuan5"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_marginBottom="10dp"
                    android:backgroundTint="#0D47A1"
                    android:text="🌐  Buka Web Bina Desa"
                    android:textColor="#FFFFFF"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    app:cornerRadius="14dp" />

            </LinearLayout>
        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
